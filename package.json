{
  "name": "smb-hall-management",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:native": "VITE_CAPACITOR=true vue-tsc -b && VITE_CAPACITOR=true vite build",
    "preview": "vite preview",
    "backup": "node scripts/backup-data.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npm run build:native && cap sync",
    "cap:sync:ios": "npm run build:native && cap sync ios",
    "cap:sync:android": "npm run build:native && cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "npm run build:native && cap run ios",
    "cap:run:android": "npm run build:native && cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@primeuix/themes": "^2.0.3",
    "@supabase/supabase-js": "^2.91.1",
    "apexcharts": "^5.3.6",
    "date-fns": "^4.1.0",
    "mhah-panchang": "^1.2.0",
    "pdfmake": "^0.3.3",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "vue3-apexcharts": "^1.10.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/pdfmake": "^0.2.12",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.1.4"
  }
}
