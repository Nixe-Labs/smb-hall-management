# ── Capacitor / native build artefacts ───────────────────────────
# The native shells (ios/, android/) ARE committed — they're project
# files. Only the build outputs, derived data, and generated caches
# are ignored.

# Web assets copied into the shells by `cap sync` (regenerated every
# build from dist/)
ios/App/App/public/
android/app/src/main/assets/public/

# Xcode
ios/App/build/
ios/App/DerivedData/
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/.sourcery/

# Android
android/.gradle/
android/local.properties
android/captures/
android/.idea/
android/app/release/
android/app/build/
android/build/
android/keystore.properties
android/app/google-services.json

# Generated Capacitor configs that are written by cap sync — the
# source of truth is capacitor.config.ts at the repo root.
ios/App/App/capacitor.config.json
android/app/src/main/assets/capacitor.config.json

# Local data backups (contain customer PII — never commit)
backups/
